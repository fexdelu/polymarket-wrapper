# Polymarket API credentials
# Copy this file to ~/.hermes/polymarket.env and fill in your values
# NEVER commit polymarket.env — it's in .gitignore
#
# To get these:
# 1. Go to https://polymarket.com/settings/api
# 2. Create a new API key
# 3. Save the key, secret, and passphrase
#
# PM_FUNDER is your Polygon wallet address with USDC balance
# PM_PRIVATE_KEY is the EOA that OWNS that wallet (for signing)

PM_PRIVATE_KEY=0x_your_private_key_here
PM_API_KEY=your_api_key_here
PM_API_SECRET=your_api_secret_here
PM_API_PASSPHRASE=your_passphrase_here
PM_FUNDER=0x_your_funded_wallet_address
